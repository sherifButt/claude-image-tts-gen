{
  "name": "claude-image-tts-gen-mcp",
  "version": "0.8.7",
  "description": "MCP server for multi-provider image and TTS generation",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "claude-image-tts-gen": "./dist/server.js",
    "claude-image-tts-gen-cli": "./dist/cli.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "build:tsc": "tsc",
    "build:postbuild": "node scripts/postbuild.mjs",
    "build": "npm run clean && npm run build:tsc && npm run build:postbuild",
    "start": "node dist/server.js",
    "start:cli": "node dist/cli.js --help",
    "pricing:refresh": "node dist/pricing/refresh.js",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@imgly/background-removal-node": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "openai": "^6.34.0",
    "proper-lockfile": "^4.1.2",
    "sharp": "^0.34.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}

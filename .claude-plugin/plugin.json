{
  "name": "claude-image-tts-gen",
  "description": "Multi-provider image and text-to-speech generation with cost tracking and batch mode.",
  "version": "0.8.5",
  "author": {
    "name": "Sherif Butt"
  },
  "repository": "https://github.com/sherifButt/claude-image-tts-gen",
  "license": "MIT",
  "mcpServers": {
    "claude-image-tts-gen": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp-server/dist/server.js"],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY:-}",
        "OPENAI_API_KEY": "${OPENAI_API_KEY:-}",
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY:-}",
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY:-}",
        "GEMINI_DEFAULT_VOICE": "${GEMINI_DEFAULT_VOICE:-}",
        "OPENAI_DEFAULT_VOICE": "${OPENAI_DEFAULT_VOICE:-}",
        "ELEVENLABS_DEFAULT_VOICE": "${ELEVENLABS_DEFAULT_VOICE:-}",
        "LOCAL_DEFAULT_VOICE": "${LOCAL_DEFAULT_VOICE:-}",
        "LOCAL_BASE_URL": "${LOCAL_BASE_URL:-http://localhost:8880/v1}",
        "LOCAL_ENABLED": "${LOCAL_ENABLED:-false}",
        "VOICEBOX_BASE_URL": "${VOICEBOX_BASE_URL:-http://localhost:17493}",
        "VOICEBOX_ENABLED": "${VOICEBOX_ENABLED:-false}",
        "VOICEBOX_DEFAULT_VOICE": "${VOICEBOX_DEFAULT_VOICE:-}",
        "GEMINI_IMAGE_MODEL": "${GEMINI_IMAGE_MODEL:-}",
        "IMAGE_OUTPUT_DIR": "${IMAGE_OUTPUT_DIR:-./generated-images}",
        "AUDIO_OUTPUT_DIR": "${AUDIO_OUTPUT_DIR:-./generated-audio}",
        "STATE_DIR": "${STATE_DIR:-}",
        "AUTOPLAY": "${AUTOPLAY:-false}",
        "REWRITE_PROMPTS": "${REWRITE_PROMPTS:-true}",
        "EMIT_SIDECAR": "${EMIT_SIDECAR:-true}",
        "LOG_LEVEL": "${LOG_LEVEL:-info}"
      }
    }
  }
}
